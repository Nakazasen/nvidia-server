{
  "name": "nvidia-nim-mcp-workspace",
  "version": "1.0.0",
  "description": "NVIDIA NIM MCP Server and Tools",
  "main": "tools/nvidia_mcp.mjs",
  "type": "module",
  "scripts": {
    "start": "node tools/nvidia-server.mjs",
    "cli": "node tools/nvidia-cli.mjs",
    "agent": "node tools/nvidia-cli-agent.mjs",
    "agent:audit": "node tools/agent-capability-harness.mjs",
    "browser:smoke": "node tools/browser-smoke.mjs",
    "manual:proof": "node tests/manual-ui-create-apply-e2e.test.mjs",
    "edit:proof": "node tests/existing-file-edit-workflow.test.mjs",
    "delete:proof": "node tests/delete-file-safety-proof.test.mjs",
    "move:proof": "node tests/move-rename-file-workflow-proof.test.mjs",
    "live:proof": "node tests/live-provider-create-apply-proof.test.mjs",
    "write:create:proof": "node tests/real-write-create-flow.test.mjs",
    "apply:proof": "node tests/apply-pending-edit-to-disk.test.mjs",
    "budget:check": "node tools/performance-budget.mjs",
    "runtime:hygiene": "node tools/runtime-hygiene.mjs --dry-run",
    "bridge:preflight": "node tools/bridge-preflight.mjs",
    "bridge:preflight:test": "node tests/bridge-preflight.test.mjs",
    "bridge:preflight:e2e": "node tests/bridge-preflight-e2e.test.mjs",
    "desktop": "electron electron-main.js",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.nvidia.nim.agent",
    "productName": "NVIDIA NIM Agent IDE",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "diff": "^9.0.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "openai": "^4.0.0",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "playwright-core": "^1.59.1"
  }
}
